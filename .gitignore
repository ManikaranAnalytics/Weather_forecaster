# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
venv311/
.env/
.env
.env.*

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Pytest cache
.pytest_cache/

# MyPy cache
.mypy_cache/

# Byte-compiled / optimized / DLL files
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.build/
dist/
build/
*.egg-info/
.eggs/
pip-wheel-metadata/

# IDE/editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.log
*.tmp
*.temp
zip/

# Database files (ignore any local DB files)
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-wal
*.sqlite-shm

# Ignore secret/local config
*.env
credentials.json
secrets.json

# Ignore generated model outputs / caches
*.h5
*.pb
*.tflite
*.keras

# Ignore streamlit temp uploads / cache
.streamlit/

# Ignore large media outputs
*.mp4
*.avi
*.mov
*.mkv
*.jpg
*.jpeg
*.png

# Keep UI assets and small test fixtures tracked
!assets/
!assets/**
!tests/fixtures/
!tests/fixtures/**

# Large data / local weight parks
data/dataset/
data/frames/
data/videos/
data/outputs/
models/yolo/
models/clip/
weights/

# Nested clone (separate repo)
Weather_forecaster/
